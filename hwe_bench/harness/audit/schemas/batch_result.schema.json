{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HWE Bench Audit Batch Result",
  "type": "object",
  "required": ["batch_id", "case_count", "summary", "cases"],
  "properties": {
    "batch_id": {"type": "string"},
    "case_count": {"type": "integer"},
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["number", "status", "trajectory_audit", "patch_review"],
        "properties": {
          "number": {"type": "integer"},
          "status": {
            "type": "string",
            "enum": ["resolved", "unresolved", "incomplete", "error", "empty_patch"]
          },
          "trajectory_audit": {
            "type": "object",
            "required": ["verdict"],
            "properties": {
              "verdict": {"type": "string", "enum": ["clean", "suspicious"]},
              "evidence": {"type": "array", "items": {"type": "object"}}
            },
            "additionalProperties": true
          },
          "patch_review": {
            "type": "object",
            "required": ["verdict", "confidence", "reason"],
            "properties": {
              "verdict": {
                "type": "string",
                "enum": [
                  "genuine_fix", "suspicious", "hack",
                  "true_unresolved", "high_conf_false_negative", "needs_investigation"
                ]
              },
              "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
              "reason": {"type": "string"},
              "tb_coupling_type": {"type": "string"}
            },
            "additionalProperties": true
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "file": {"type": "string"},
                "excerpt": {"type": "string"}
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
